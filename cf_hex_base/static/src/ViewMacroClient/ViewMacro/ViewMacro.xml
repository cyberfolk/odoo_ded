<t t-name="ViewMacro">
    <t t-if="store.macro">
        <!-- VIEW V1-->
        <t t-if="store.macro.type == 'v1_19_q'">
            <div class="macro_form mf_v1 m-auto">
                <t t-foreach="store.macro.quad_ids" t-as="quad" t-key="quad.id">
                    <div class="quad_v1 bg-dark " t-att-style="getQuadStyleV1(quad)">
                        <t t-foreach="quad.hex_ids" t-as="hex" t-key="hex.id">
                            <HexHex hex_asset_id="hex.hex_asset_id"
                                    index="hex.index"
                                    color="hex.color"
                                    dim="'hex_mf_v1'"
                                    id="hex.id"/>
                        </t>
                    </div>
                </t>
            </div>
        </t>
        <!-- VIEW V2-->
        <t t-else="">
            <div class="macro_form m-auto">
                <t t-foreach="store.macro.quad_rows" t-as="quad_row" t-key="quad_row[0].id">
                    <div class="d-flex">
                        <t t-foreach="quad_row" t-as="quad" t-key="quad.col">
                            <div class="quad_v2 bg-dark">
                                <t t-foreach="quad.hex_ids" t-as="hex" t-key="hex.id">
                                    <HexHex hex_asset_id="hex.hex_asset_id"
                                            color="hex.color"
                                            dim="'hex_mf_v2'"
                                            row="hex.row"
                                            col="hex.col"
                                            id="hex.id"/>
                                </t>
                            </div>
                        </t>
                    </div>
                </t>
            </div>
        </t>
    </t>
    <t t-else="">
        <div class="macro_form m-auto mt-5 text-center">
            <h1>Nessuna Mappa</h1>
            <h2>Creane una dal menù</h2>
        </div>
    </t>
</t>