<odoo>
    <record id="hex_macro_view_tree" model="ir.ui.view">
        <field name="name">hex.macro.tree</field>
        <field name="model">hex.macro</field>
        <field name="arch" type="xml">
            <tree edit="0" delete="0">
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="hex_macro_view_form" model="ir.ui.view">
        <field name="name">hex.macro.form</field>
        <field name="model">hex.macro</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" class="oe_inline"/>
                        </h1>
                    </div>
                    <!--                    <group>-->
                    <!--                        <group>-->
                    <!--                            <field name="row_min"/>-->
                    <!--                            <field name="row_max"/>-->
                    <!--                            <field name="row_num"/>-->
                    <!--                            <field name="col_min"/>-->
                    <!--                            <field name="col_max"/>-->
                    <!--                            <field name="col_num"/>-->
                    <!--                        </group>-->
                    <!--                    </group>-->
                    <notebook>
                        <page string="Quadranti" name="page_quad_ids">
                            <field name="quad_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
