<odoo>
    <record id="hex_quad_view_tree" model="ir.ui.view">
        <field name="name">hex.quad.tree</field>
        <field name="model">hex.quad</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="type" widget="badge"
                       decoration-info="type  == 'v1_19_q'"
                       decoration-primary="type == 'v2_nolimit_q'"/>
                <field name="index"/>
                <field name="circle_order"/>
                <field name="circle_number"/>
                <field name="row"/>
                <field name="col"/>
                <field name="map_id"/>
                <field name="border_N"/>
                <field name="border_NE"/>
                <field name="border_SE"/>
                <field name="border_S"/>
                <field name="border_SW"/>
                <field name="border_NW"/>
            </tree>
        </field>
    </record>

    <record id="hex_quad_view_form" model="ir.ui.view">
        <field name="name">hex.quad.form</field>
        <field name="model">hex.quad</field>
        <field name="arch" type="xml">
            <form js_class="quad_form">
                <sheet>
                    <header>
                        <field name="id" widget="o2m_expand_popup" model="hex.quad" model_parent="hex.map"/>
                    </header>
                    <group>
                        <group col="1">
                            <group>
                                <field class="fw-bold h1" colspan="2" nolabel="1" readonly="1" name="name"/>
                            </group>
                            <group name="group_hook_widget">
                                <!-- Esteso con un xpath in un modulo successivo -->
                            </group>
                            <group string="Missing Hexes" name="quad_missing_ids">
                                <field readonly="1" colspan="2" nolabel="1" name="missing_ids" widget='many2many_tags'/>
                            </group>
                        </group>
                        <group col="1">
                            <group col="4" string="Info Quad" name="info_quad">
                                <group>
                                    <field name="type" readonly="1"/>
                                </group>
                                <group>
                                    <field name="code"/>
                                </group>
                                <group invisible="type != 'v1_19_q'">
                                    <field name="index"/>
                                </group>
                                <group invisible="type != 'v1_19_q'">
                                    <field name="circle_number"/>
                                </group>
                                <group invisible="type != 'v2_nolimit_q'">
                                    <field name="row" readonly="1"/>
                                </group>
                                <group invisible="type != 'v2_nolimit_q'">
                                    <field name="col" readonly="1"/>
                                </group>
                            </group>
                            <group string="Internal Hexes" name="quad_hex_ids">
                                <field readonly="1" colspan="2" nolabel="1" name="hex_ids">
                                    <tree create="0" edit="0" delete="0">
                                        <field name="code"/>
                                        <field name="row" column_invisible="parent.type != 'v2_nolimit_q'"/>
                                        <field name="col" column_invisible="parent.type != 'v2_nolimit_q'"/>
                                        <field name="index" column_invisible="parent.type != 'v1_19_q'"/>
                                        <field name="circle_order" column_invisible="parent.type != 'v1_19_q'"/>
                                        <field name="circle_number" column_invisible="parent.type != 'v1_19_q'"/>
                                        <field name="border_N" column_invisible="parent.type != 'v1_19_q'"/>
                                        <field name="border_NE" column_invisible="parent.type != 'v1_19_q'"/>
                                        <field name="border_SE" column_invisible="parent.type != 'v1_19_q'"/>
                                        <field name="border_S" column_invisible="parent.type != 'v1_19_q'"/>
                                        <field name="border_SW" column_invisible="parent.type != 'v1_19_q'"/>
                                        <field name="border_NW" column_invisible="parent.type != 'v1_19_q'"/>
                                    </tree>
                                </field>
                            </group>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>