<odoo>
    <record id="hex_group_view_tree" model="ir.ui.view">
        <field name="name">hex.group.tree.base</field>
        <field name="model">hex.group</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="color" widget="color"/>
                <field name="map_id"/>
            </tree>
        </field>
    </record>

    <record id="hex_group_view_form" model="ir.ui.view">
        <field name="name">hex.group.form.base</field>
        <field name="model">hex.group</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="color" widget="color"/>
                            <field name="map_id"/>
                            <field name="hex_ids"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>