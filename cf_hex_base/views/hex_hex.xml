<odoo>
    <record id="hex_hex_view_search" model="ir.ui.view">
        <field name="name">hex.hex.search</field>
        <field name="model">hex.hex</field>
        <field name="arch" type="xml">
            <search>
                <filter name="filter_type_v1_19_q" string="Tipo V1" domain="[('type', '=', 'v1_19_q')]"/>
                <filter name="filter_type_v2_nolimit_q" string="Tipo V2" domain="[('type', '=', 'v2_nolimit_q')]"/>
                <filter name="groupby_type" string="Tipo" context="{'group_by': 'type'}"/>
                <filter name="groupby_map_id" string="Mappa" context="{'group_by': 'map_id'}"/>
            </search>
        </field>
    </record>

    <record id="hex_hex_view_tree" model="ir.ui.view">
        <field name="name">hex.hex.tree.base</field>
        <field name="model">hex.hex</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="type" widget="badge" optional="show"
                       decoration-info="type  == 'v1_19_q'"
                       decoration-primary="type == 'v2_nolimit_q'"/>
                <field name="quad_id" optional="show"/>
                <field name="map_id" optional="show"/>
                <field name="index" optional="hide"/>
                <field name="circle_order" optional="hide"/>
                <field name="circle_number" optional="hide"/>
                <field name="row" optional="hide"/>
                <field name="col" optional="hide"/>
                <field name="border_N" optional="hide"/>
                <field name="border_NE" optional="hide"/>
                <field name="border_SE" optional="hide"/>
                <field name="border_S" optional="hide"/>
                <field name="border_SW" optional="hide"/>
                <field name="border_NW" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="hex_hex_view_form" model="ir.ui.view">
        <field name="name">hex.hex.form.base</field>
        <field name="model">hex.hex</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code" readonly="1"/>
                            <field name="type" readonly="1"/>
                            <field name="index" readonly="1" invisible="type != 'v1_19_q'"/>
                            <field name="circle_order" invisible="type != 'v1_19_q'"/>
                            <field name="circle_number" invisible="type != 'v1_19_q'"/>
                            <field name="row" invisible="type != 'v2_nolimit_q'" readonly="1"/>
                            <field name="col" invisible="type != 'v2_nolimit_q'" readonly="1"/>
                            <field name="quad_id" readonly="1"/>
                            <field name="map_id" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>