<odoo>
    <record id="point_of_interest_view_form" model="ir.ui.view">
        <field name="name">point_of_interest_view_form</field>
        <field name="model">point.of.interest</field>
        <field name="inherit_id" ref="cf_ded_base.point_of_interest_view_form"/>
        <field name="arch" type="xml">

            <!-- Smart Per le relazioni -->
            <xpath expr="//sheet/group" position="before">
                <div class="oe_button_box" name="button_box">
                    <button name="action_open_narratives" type="object" class="oe_stat_button" icon="fa-link">
                        <field string="Relazioni" name="narrative_relations_count" widget="statinfo"/>
                    </button>
                    <button name="action_add_outgoing_narrative" type="object" class="oe_stat_button" icon="fa-plus" string="R Attiva"/>
                    <button name="action_add_incoming_narrative" type="object" class="oe_stat_button" icon="fa-plus" string="R Passiva"/>
                </div>
            </xpath>

        </field>
    </record>
</odoo>
