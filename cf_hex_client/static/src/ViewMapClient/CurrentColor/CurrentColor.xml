<div t-name="CurrentColor" class="current-color mt-2">
    <div class="current-color__title" t-att-class="store.currentColor ? 'd-none' : ''">
        <span>Colloca Bioma</span>
    </div>

    <div class="current-color__hide-title" t-att-class="store.currentColor ? 'd-block' : ''">
        <span>Scegli un Bioma e collocalo sugli Esagoni:</span>
    </div>
    <div class="current-color__color-list mx-1 row">
        <t t-foreach="store.biomeList" t-as="biome" t-key="biome">
            <button class="current-color__btn btn p-2 me-1"
                    t-att-style="'background-color: ' + biome.color + '; color: ' + biome.color_name_contrast"
                    t-on-click="() => this.setCurrentBiome(biome)"
                    t-att-class="store.currentBiome == biome.color ? 'current-color__btn--active' : ''"
                    t-esc="biome.name">
            </button>
        </t>
    </div>
</div>
