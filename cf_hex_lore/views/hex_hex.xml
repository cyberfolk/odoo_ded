<odoo>
    <record id="hex_hex_view_tree_inherited" model="ir.ui.view">
        <field name="name">hex.hex.tree.lore</field>
        <field name="model">hex.hex</field>
        <field name="inherit_id" ref="cf_hex_base.hex_hex_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='col']" position="before">
                <field name="biome_id"/>
                <field name="sml"/>
                <field name="npc_ids" widget="many2many_tags" optional="show"/>
                <field name="faction_ids" widget="many2many_tags" optional="show"/>
                <field name="structure_id" optional="show"/>
                <field name="creature_id" optional="show"/>
                <field name="completion_percentage" widget="progressbar"/>
            </xpath>
        </field>
    </record>

    <record id="hex_hex_view_form" model="ir.ui.view">
        <field name="name">hex.hex.form</field>
        <field name="model">hex.hex</field>
        <field name="inherit_id" ref="cf_hex_base.hex_hex_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="replace">
                <sheet>
                    <div class="oe_title" colspan="2">
                        <label for="name" class="oe_inline"/>
                        <h1>
                            <field class="text-nowrap" name="name" nolabel="1"/>
                        </h1>
                    </div>
                    <group class="mt-3" col="6">
                        <group colspan="2">
                            <field name="completion_percentage" widget="progressbar"/>
                            <field name="biome_id" required="1"/>
                            <field name="sml" required="1"/>
                            <field name="structure_id"/>
                            <!-- todo aggiungere restrizione su mostro figo o interessante -->
                            <field name="creature_id"/>
                        </group>
                        <group colspan="2">
                            <field name="encounter_encounter_ids" widget="many2many_tags"/>
                            <field name="wild_encounter_ids" widget="many2many_tags" domain="[('sml', '=', sml)]"/>
                            <field name="npc_ids" widget="many2many_tags"/>
                            <field name="status" widget="badge"
                                   decoration-danger="status  == 'script'"
                                   decoration-success="status == 'grid'"/>
                        </group>
                        <group colspan="2">
                            <field name="image" widget="image" nolabel="1" colspan="2"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Descrizione" name="page_description">
                            <field name="description"/>
                        </page>
                        <page string="Incontri Casuali" name="page_encounter_encounter_ids">
                            <field name="encounter_encounter_ids" colspan="2" nolabel="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="description"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Scontri Selvaggi" name="page_wild_encounter_ids">
                            <field name="wild_encounter_ids" colspan="2" nolabel="1">
                                <tree>
                                    <field name="sml"/>
                                    <field name="name"/>
                                </tree>
                            </field>
                        </page>
                        <page string="NPCs" name="page_npc_ids">
                            <field name="npc_ids" colspan="2" nolabel="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="tag_ids"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Immagini" name="page_image_gallery_ids">
                            <field name="image_gallery_ids" widget="MultipleImage"/>
                            <field name="image_gallery_ids" widget="many2many_binary"/>
                        </page>
                        <page string="Parametri Mappa" name="page_map_params">
                            <group name="group_map_params">
                                <group name="group_map_params_left">
                                    <field name="code"/>
                                    <field name="type" widget="badge" optional="show"
                                           decoration-info="type  == 'v1_19_q'"
                                           decoration-primary="type == 'v2_nolimit_q'"/>
                                    <field name="index" readonly="1" invisible="type != 'v1_19_q'"/>
                                    <field name="circle_order" invisible="type != 'v1_19_q'"/>
                                    <field name="circle_number" invisible="type != 'v1_19_q'"/>
                                    <field name="row" invisible="type != 'v2_nolimit_q'" readonly="1"/>
                                    <field name="col" invisible="type != 'v2_nolimit_q'" readonly="1"/>
                                    <field name="quad_id" readonly="1"/>
                                </group>
                                <group name="group_map_params_right">
                                    <field name="border_N" readonly="1"/>
                                    <field name="border_NE" readonly="1"/>
                                    <field name="border_SE" readonly="1"/>
                                    <field name="border_S" readonly="1"/>
                                    <field name="border_SW" readonly="1"/>
                                    <field name="border_NW" readonly="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </xpath>
        </field>
    </record>
</odoo>