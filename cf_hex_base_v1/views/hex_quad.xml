<odoo>
    <record id="hex_quad_view_search" model="ir.ui.view">
        <field name="name">hex_quad_view_search</field>
        <field name="model">hex.quad</field>
        <field name="inherit_id" ref="cf_hex_base.hex_quad_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <filter name="filter_type_v1_19_q" string="Tipo V1" domain="[('type', '=', 'v1_19_q')]"/>
            </xpath>
        </field>
    </record>

    <record id="hex_quad_view_tree" model="ir.ui.view">
        <field name="name">hex_quad_view_tree</field>
        <field name="model">hex.quad</field>
        <field name="inherit_id" ref="cf_hex_base.hex_quad_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='type']" position="attributes">
                <attribute name="decoration-info">type == 'v1_19_q'</attribute>
            </xpath>
            <xpath expr="//field[@name='index']" position="after">
                <field name="circle_order"/>
                <field name="circle_number"/>
            </xpath>
        </field>
    </record>

    <record id="hex_quad_view_form" model="ir.ui.view">
        <field name="name">hex_quad_view_form</field>
        <field name="model">hex.quad</field>
        <field name="inherit_id" ref="cf_hex_base.hex_quad_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='group_hook_widget']" position="after">
                <group string="Missing Hexes" name="quad_missing_ids" invisible="type != 'v1_19_q'">
                    <field readonly="1" colspan="2" nolabel="1" name="missing_ids" widget='many2many_tags'/>
                </group>
            </xpath>
            <xpath expr="//group[@name='info_quad_col_1']/field[@name='type']" position="attributes">
                <attribute name="decoration-info">type == 'v1_19_q'</attribute>
            </xpath>
            <xpath expr="//group[@name='info_quad_col_1']" position="after">
                <group name="info_quad_col_2" invisible="type != 'v1_19_q'">
                    <field name="index" readonly="1"/>
                    <field name="circle_number"/>
                    <field name="circle_order"/>
                </group>
            </xpath>
            <xpath expr="//tree/field[@name='code']" position="after">
                <field name="index" column_invisible="parent.type != 'v1_19_q'"/>
                <field name="circle_order" column_invisible="parent.type != 'v1_19_q'"/>
                <field name="circle_number" column_invisible="parent.type != 'v1_19_q'"/>
                <field name="border_N" column_invisible="parent.type != 'v1_19_q'"/>
                <field name="border_NE" column_invisible="parent.type != 'v1_19_q'"/>
                <field name="border_SE" column_invisible="parent.type != 'v1_19_q'"/>
                <field name="border_S" column_invisible="parent.type != 'v1_19_q'"/>
                <field name="border_SW" column_invisible="parent.type != 'v1_19_q'"/>
                <field name="border_NW" column_invisible="parent.type != 'v1_19_q'"/>
            </xpath>
        </field>
    </record>
</odoo>