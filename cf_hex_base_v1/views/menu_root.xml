<odoo>
    <record id="action_menu_quad" model="ir.actions.act_window">
        <field name="name">Quadranti</field>
        <field name="res_model">hex.quad</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_groupby_map_id':1}</field>
    </record>

    <record id="action_menu_hex" model="ir.actions.act_window">
        <field name="name">Hex</field>
        <field name="res_model">hex.hex</field>
        <field name="view_mode">tree,form</field>
<!--        <field name="context">{'search_default_groupby_map_id':1}</field>-->
<!--        <field name="view_ids">[(5, 0, 0),-->
<!--            (0, 0, {'view_mode': 'tree', 'view_id': ref('cf_hex_base.hex_hex_view_tree')}),-->
<!--            (0, 0, {'view_mode': 'form', 'view_id': ref('cf_hex_base.hex_hex_view_form')})]-->
<!--        </field>-->
    </record>

    <record id="action_menu_map" model="ir.actions.act_window">
        <field name="name">Mappe</field>
        <field name="res_model">hex.map</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem sequence="0" id="menu_root" name="Hex Map" web_icon="cf_hex_base,static/description/icon.png">
        <menuitem sequence="10" id="menu_hex_map_conf" name="Configurazione">
            <menuitem sequence="1" id="menu_hex_map_conf_base_element" name="Elementi Base">
                <menuitem sequence="1" id="menu_hex_map_conf_base_elem_map" name="Mappe" action="action_menu_map"/>
                <menuitem sequence="2" id="menu_hex_map_conf_base_elem_quad" name="Quadranti" action="action_menu_quad"/>
                <menuitem sequence="3" id="menu_hex_map_conf_base_elem_hex" name="Esagoni" action="action_menu_hex"/>
            </menuitem>
        </menuitem>
    </menuitem>
</odoo>