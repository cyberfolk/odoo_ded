<odoo>
    <record id="hex_hex_view_tree" model="ir.ui.view">
        <field name="name">hex_hex_view_tree</field>
        <field name="model">hex.hex</field>
        <field name="inherit_id" ref="cf_hex_base.hex_hex_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='type']" position="attributes">
                <attribute name="decoration-info">type == 'v1_19_q'</attribute>
            </xpath>
            <xpath expr="//field[@name='index']" position="after">
                <field name="circle_order" optional="hide"/>
                <field name="circle_number" optional="hide"/>
            </xpath>
        </field>
    </record>

    <record id="hex_hex_view_form" model="ir.ui.view">
        <field name="name">hex_hex_view_form</field>
        <field name="model">hex.hex</field>
        <field name="inherit_id" ref="cf_hex_base.hex_hex_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='index']" position="after">
                <field name="circle_order" invisible="type != 'v1_19_q'"/>
                <field name="circle_number" invisible="type != 'v1_19_q'"/>
            </xpath>
        </field>
    </record>
</odoo>