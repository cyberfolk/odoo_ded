<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_creature_roster_template_v1">
        <t t-call="web.basic_layout">
            <style>
                .npc-card {
                border: 1px solid black;
                border-radius: 0.5rem;
                text-align: center;
                width: 50%;
                height: 467px;
                }
            </style>

            <t t-set="npc_list" t-value="docs[0].creature_ids"/>
            <t t-set="npc_list_grouped2" t-value="[npc_list[i:i+2] for i in range(0, len(npc_list), 2)]"/>
            <t t-foreach="npc_list_grouped2" t-as="npc_sublist2">
                <div class="d-flex" style="page-break-inside: avoid;">
                    <t t-foreach="npc_sublist2" t-as="npc">
                        <div class="npc-card">
                            <h1 style="height: 10%" class="m-0 p-0">
                                <t t-esc="npc.name"/>
                            </h1>
                            <div class="m-auto" style="height: 90%; overflow: hidden;">
                                <img t-if="npc.image" style="height: 100%; border-radius: 0 0 0.5rem 0.5rem;"
                                     t-att-src="image_data_uri(npc.image)"/>
                            </div>
                        </div>
                    </t>
                </div>
            </t>

        </t>
    </template>

    <template id="report_creature_roster_template_v2">
        <t t-call="web.basic_layout">
            <style>
                @import url('https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700&amp;display=swap');
                @import url('https://fonts.googleapis.com/css2?family=IM+Fell+English+SC&amp;display=swap');
                @import url('https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700&amp;family=EB+Garamond&amp;display=swap');

                .cell {
                border: 6px double #8B0000; /* dark red medieval border */
                border-radius: 1rem;
                height: 465px;
                page-break-inside: avoid;
                margin-bottom: 0.2rem;
                background: #fdf3dc; /* parchment background */
                box-shadow: 0 0 10px #00000080;
                <!-- TODO Scegliere font o questo o toglierlo e lasciare quello di default che è più leggibile -->
                <!-- font-family: 'EB Garamond', serif;-->
                color: #2b1d0e;
                }

                .cell-dx {
                border-right: 6px double #8B0000;
                height: 100%;
                width: 50%;
                }

                .cell h1 {
                font-family: 'Cinzel Decorative', cursive;
                color: #4b0000;
                text-shadow: 1px 1px #f2e1c2;
                border-bottom: 2px solid #4b0000;
                padding-bottom: 0.3rem;
                margin-bottom: 0.5rem;
                }

                .cell .description {
                font-size: 14px;
                line-height: 1.5;
                color: #3b2a1a;
                }
            </style>

            <t t-set="npc_list" t-value="docs[0].creature_ids"/>
            <t t-foreach="npc_list" t-as="npc">
                <div class="cell row">
                    <div class="cell-dx">
                        <div class="m-auto w-100 h-100" style="overflow: hidden;">
                            <img t-if="npc.image" style="width: 100%; border-radius:  0.5rem 0 0 0.5rem;"
                                 t-att-src="image_data_uri(npc.image)"/>
                        </div>
                    </div>
                    <div class="w-50 h-100 p-3">
                        <h1>
                            <t t-esc="npc.name"/>
                        </h1>
                        <t t-esc="npc.description"/>
                    </div>

                </div>
            </t>

        </t>
    </template>

</odoo>
