<odoo>
    <record id="settlement_settlement_view_tree" model="ir.ui.view">
        <field name="name">settlement.settlement.tree</field>
        <field name="model">settlement.settlement</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="scale"/>
            </tree>
        </field>
    </record>

    <record id="settlement_settlement_view_form" model="ir.ui.view">
        <field name="name">settlement.settlement.form</field>
        <field name="model">settlement.settlement</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group col="6">
                        <group colspan="4">
                            <div class="oe_title mb-3" colspan="2">
                                <label for="name" class="fw-bold oe_inline mb-0"/>
                                <h1>
                                    <field class="text-nowrap" name="name" nolabel="1"/>
                                </h1>
                            </div>
                            <group string="Info Base" name="group_fields_base">
                                <field name="scale"/>
                                <field name="attitude"/>
                                <field name="needs"/>
                                <field name="offers"/>
                                <field name="lore_level"/>
                                <field name="code" class="text-nowrap text-muted fst-italic" readonly="1" groups="base.group_no_one"/>
                            </group>
                            <group string="Entità Narrative" name="group_fields_en_base">
                                <field widget="many2many_tags" name="monster_ids"/>
                                <field widget="many2many_tags" name="poi_ids"/>
                                <field widget="many2many_tags" name="lore_item_ids"/>
                                <field widget="many2many_tags" name="artifact_ids"/>
                                <field widget="many2many_tags" name="quest_ids"/>
                                <field widget="many2many_tags" name="creature_ids"/>
                                <field widget="many2many_tags" name="faction_ids"/>
                                <field widget="many2many_tags" name="npc_ids"/>
                            </group>
                        </group>
                        <group colspan="2">
                            <field name="image" widget="image" nolabel="1" colspan="2"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="Descrizione">
                            <field name="description" colspan="4"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
