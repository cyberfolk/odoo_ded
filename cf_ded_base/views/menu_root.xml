<odoo>
    <record id="action_menu_biome_biome" model="ir.actions.act_window">
        <field name="name">Tipi di Biomi</field>
        <field name="res_model">biome.biome</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="context">{'search_default_filter_state_active':1}</field>
    </record>

    <record id="action_menu_structure_structure" model="ir.actions.act_window">
        <field name="name">Strutture</field>
        <field name="res_model">structure.structure</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_menu_creature_creature" model="ir.actions.act_window">
        <field name="name">Creature</field>
        <field name="res_model">creature.creature</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('is_base', '=', True)]</field>
    </record>

    <record id="action_menu_creature_tag" model="ir.actions.act_window">
        <field name="name">Creature Tag</field>
        <field name="res_model">creature.tag</field>
        <field name="view_mode">tree,form,kanban</field>
    </record>

    <record id="action_menu_creature_type" model="ir.actions.act_window">
        <field name="name">Creature Tipi</field>
        <field name="res_model">creature.type</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_menu_creature_encounter" model="ir.actions.act_window">
        <field name="name">Creature Scontri</field>
        <field name="res_model">creature.encounter</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_menu_creature_encounter_line" model="ir.actions.act_window">
        <field name="name">Creature Scontri Linee</field>
        <field name="res_model">creature.encounter.line</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_menu_creature_faction" model="ir.actions.act_window">
        <field name="name">Fazioni</field>
        <field name="res_model">creature.faction</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="context">{'search_default_filter_state_active_and_is_not_child':1}</field>
    </record>

    <record id="action_menu_encounter_encounter" model="ir.actions.act_window">
        <field name="name">Elenco Incontri Random</field>
        <field name="res_model">encounter.encounter</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_menu_creature_npc" model="ir.actions.act_window">
        <field name="name">Elenco NPC</field>
        <field name="res_model">creature.creature</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('is_npc', '=', True)]</field>
        <field name="context">{'default_is_npc':1}</field>
    </record>

    <record id="action_menu_creature_roster" model="ir.actions.act_window">
        <field name="name">Elenco NPC</field>
        <field name="res_model">creature.roster</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_menu_settlement_settlement" model="ir.actions.act_window">
        <field name="name">Insediamenti</field>
        <field name="res_model">settlement.settlement</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_menu_quest_quest" model="ir.actions.act_window">
        <field name="name">Missioni</field>
        <field name="res_model">quest.quest</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_menu_point_of_interest" model="ir.actions.act_window">
        <field name="name">Punti d'Interesse</field>
        <field name="res_model">point.of.interest</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_menu_creature_legendary" model="ir.actions.act_window">
        <field name="name">Creature Leggendarie</field>
        <field name="res_model">creature.creature</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('is_legendary', '=', True)]</field>
        <field name="context">{'default_is_legendary':1}</field>
    </record>

    <menuitem sequence="0" id="menu_root" name="D&amp;D" web_icon="cf_ded_base,static/description/icon.png">
        <menuitem sequence="1" id="menu_biome" name="Biomi" action="action_menu_biome_biome"/>
        <menuitem sequence="2" id="menu_structure" name="Strutture" action="action_menu_structure_structure"/>
        <menuitem sequence="3" id="menu_faction" name="Fazioni" action="action_menu_creature_faction"/>
        <menuitem sequence="4" id="menu_settlement" name="Insediamenti" action="action_menu_settlement_settlement"/>
        <menuitem sequence="5" id="npc_root" name="NPC">
            <menuitem sequence="0" id="menu_creature_npc" name="NPC" action="action_menu_creature_npc"/>
            <menuitem sequence="1" id="menu_creature_roster" name="NPC Roster" action="action_menu_creature_roster"/>
        </menuitem>
        <menuitem sequence="6" id="menu_quest_quest" name="Missioni" action="action_menu_quest_quest"/>
        <menuitem sequence="7" id="menu_point_of_interest" name="Punti d'Interesse" action="action_menu_point_of_interest"/>
        <menuitem sequence="8" id="menu_creature_root" name="Creature">
            <menuitem sequence="0" id="menu_creature" name="Creature" action="action_menu_creature_creature"/>
            <menuitem sequence="0" id="menu_creature_monster_legendary" name="Mostri Leggendari" action="action_menu_creature_legendary"/>
            <menuitem sequence="1" id="menu_creature_tag" name="Creature Tag" action="action_menu_creature_tag"/>
            <menuitem sequence="2" id="menu_creature_type" name="Creature Tipi" action="action_menu_creature_type"/>
            <menuitem sequence="3" id="menu_creature_encounter" name="Creature Scontri" action="action_menu_creature_encounter"/>
        </menuitem>
        <menuitem sequence="9" id="menu_encounter_encounter" name="Incontri Casuali" action="action_menu_encounter_encounter"/>
    </menuitem>

</odoo>