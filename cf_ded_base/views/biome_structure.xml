<odoo>
    <record id="biome_structure_view_search" model="ir.ui.view">
        <field name="name">biome.structure.search</field>
        <field name="model">biome.structure</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="biome_ids"/>
                <filter name="group_by_biome_ids" string="Biomi" context="{'group_by': 'biome_ids'}"/>
            </search>
        </field>
    </record>

    <record id="biome_structure_view_tree" model="ir.ui.view">
        <field name="name">biome.structure.tree</field>
        <field name="model">biome.structure</field>
        <field name="arch" type="xml">
            <tree editable="top">
                <field name="name"/>
                <field name="biome_ids" widget='many2many_tags'/>
            </tree>
        </field>
    </record>
</odoo>