<odoo>
    <record id="creature_faction_view_search" model="ir.ui.view">
        <field name="name">creature.faction.search</field>
        <field name="model">creature.faction</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="state"/>
                <field name="is_parent"/>
                <field name="is_child"/>
                <filter name="filter_state_active" string="Attivi" domain="[('state', '=', 'active')]"/>
                <filter name="filter_is_parent" string="È Padre" domain="[('is_parent', '=', True)]"/>
                <filter name="filter_is_child" string="È Figlio" domain="[('is_child', '=', True)]"/>
                <filter name="filter_is_not_child" string="Non Figlio" domain="[('is_child', '=', False)]"/>
                <filter name="filter_state_active_and_is_not_child" string="Attive e non Figlio"
                        domain="['&amp;', ('state', '=', 'active'), ('is_child', '=', False)]"/>
                <filter name="groupby_state" string="State" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <record id="creature_faction_view_tree" model="ir.ui.view">
        <field name="name">creature.faction.tree</field>
        <field name="model">creature.faction</field>
        <field name="arch" type="xml">
            <!--<tree editable="top">-->
            <tree>
                <field name="code"/>
                <field name="name"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-warning="state == 'future'"
                       decoration-muted="state == 'doubtful'"
                       decoration-info="state == 'upcoming'"/>
                <field name="good_evil_axis" widget="badge"
                       decoration-info="good_evil_axis == 'good'"
                       decoration-danger="good_evil_axis == 'evil'"
                       decoration-muted="good_evil_axis == 'neutral'"/>
                <field name="cosmology" widget="badge"
                       decoration-info="cosmology == 'external'"
                       decoration-primary="cosmology == 'mirror'"
                       decoration-warning="cosmology == 'elemental'"/>
                <field name="creature_ids" widget="many2many_tags"/>
            </tree>
        </field>
    </record>

    <record id="creature_faction_view_kanban" model="ir.ui.view">
        <field name="name">creature.faction.kanban</field>
        <field name="model">creature.faction</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="state">
                <field name="name"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_content oe_kanban_global_click">
                            <div class="row">
                                <div class="col-12">
                                    <strong>
                                        <t t-esc="record.name.value"/>
                                    </strong>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="creature_faction_view_form" model="ir.ui.view">
        <field name="name">creature.faction.form</field>
        <field name="model">creature.faction</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="state" widget="badge" nolabel="1"
                           colspan="2" class=""
                           decoration-success="state == 'active'"
                           decoration-warning="state == 'future'"
                           decoration-muted="state == 'doubtful'"
                           decoration-info="state == 'upcoming'"/>
                    <div class="o_group row align-items-start">
                        <div class="col-10" colspan="2">
                            <h1>
                                <field class="text-nowrap" name="name" nolabel="1"/>
                            </h1>
                            <h3>
                                <field class="text-nowrap" name="motto" nolabel="1" placeholder="Motto della fazione..."/>
                            </h3>
                        </div>
                        <div class="col-2">
                            <field name="symbol" widget="image" nolabel="1" style="width: 100px; height: 100px;"/>
                        </div>
                    </div>

                    <group>
                        <group string="Campi Base">
                            <group>
                                <field name="code"/>
                                <field name="state"/>
                                <field name="good_evil_axis"/>
                                <field name="cosmology"/>
                            </group>
                            <group>
                                <field name="parent_id"/>
                                <field name="scale"/>
                                <field widget="many2many_tags" name="tag_ids"/>
                            </group>
                        </group>
                        <group string="Entità Narrative" name="group_fields_en">
                            <field widget="many2many_tags" name="quest_ids"/>
                            <field widget="many2many_tags" name="poi_ids"/>
                            <field widget="many2many_tags" name="npc_ids"/>
                            <field widget="many2many_tags" name="monster_ids"/>
                            <field widget="many2many_tags" name="settlement_ids"/>
                            <field widget="many2many_tags" name="lore_item_ids"/>
                        </group>
                        <notebook>
                            <page string="Info MM" name="page_info_mm">
                                <field name="description"/>
                            </page>
                            <page string="Creature" name="page_creatures">
                                <group colspan="2">
                                    <field name="desc_creature" nolabel="1" colspan="2"/>
                                </group>
                                <field name="creature_ids" nolabel="1" colspan="2"/>
                            </page>
                            <page string="NPC">
                                <group>
                                    <field name="npc_ids" nolabel="1" colspan="2">
                                        <tree editable="top">
                                            <field name="cr"/>
                                            <field name="name"/>
                                            <field name="tag_ids" widget="many2many_tags"/>
                                            <field name="description"/>
                                        </tree>
                                    </field>
                                </group>
                            </page>
                            <page string="Domande" name="page_questions">
                                <group col="3">
                                    <group colspan="1" string="Info base:">
                                        <field nolabel="1" colspan="2" name="n01_years_in_region" placeholder="1. Da quanti anni sono nella regione?"/>
                                        <field nolabel="1" colspan="2" name="n02_daily_operations" placeholder="2. Quali sono le loro operazioni quotidiane?"/>
                                        <field nolabel="1" colspan="2" name="n03_feeding_habits" placeholder="3. Come si nutrono?"/>
                                    </group>
                                    <group colspan="1" string="Gerarchia e struttura sociale">
                                        <field nolabel="1" colspan="2" name="n04_handling_threats" placeholder="4. Come si occupano delle normali minacce?"/>
                                        <field nolabel="1" colspan="2" name="n05_answering_powers" placeholder="5. A quali poteri rispondono?"/>
                                        <field nolabel="1" colspan="2" name="n06_scouts" placeholder="6. Hanno degli esploratori?"/>
                                    </group>
                                    <group colspan="1" string="Territorio e influenza">
                                        <field nolabel="1" colspan="2" name="n07_key_positions_controlled" placeholder="7. Che posizioni chiave controllano?"/>
                                        <field nolabel="1" colspan="2" name="n08_boundary_marking" placeholder="8. Come segnano i loro confini?"/>
                                        <field nolabel="1" colspan="2" name="n09_territory_claiming" placeholder="9. Come rivendicano il loro territorio?"/>
                                    </group>
                                    <group colspan="1" string="Basi">
                                        <field nolabel="1" colspan="2" name="n10_base_structure" placeholder="10. Che Struttura è la loro Base?"/>
                                        <field nolabel="1" colspan="2" name="n11_base_origin" placeholder="11. L'hanno costruita loro o esisteva già?"/>
                                        <field nolabel="1" colspan="2" name="n12_base_purpose" placeholder="12. Perché viene utilizzata?"/>
                                    </group>
                                    <group colspan="1" string="Motivazioni">
                                        <field nolabel="1" colspan="2" name="n13_long_term_goals" placeholder="13. Obbiettivi a Lungo Termine?"/>
                                        <field nolabel="1" colspan="2" name="n14_short_term_goals" placeholder="14. Obbiettivi a Breve Termine?"/>
                                        <field nolabel="1" colspan="2" name="n15_motivations" placeholder="15. Da che motivazioni sono spinti?"/>
                                        <field nolabel="1" colspan="2" name="n16_goal_strategy" placeholder="16. In che modo intendono Raggiungerli?"/>
                                    </group>
                                    <group colspan="1" string="Extra">
                                        <field nolabel="1" colspan="2" name="n17_leader_view_of_pcs" placeholder="17. I leader come vede i PG?"/>
                                        <field nolabel="1" colspan="2" name="n18_contact_with_pcs" placeholder="18.Come entrano in contatto coi PG?"/>
                                        <field nolabel="1" colspan="2" name="n19_possible_developments" placeholder="19. Possibili sviluppi della Fazione"/>
                                        <field nolabel="1" colspan="2" name="n20_faction_theme" placeholder="20. Tema della Fazione?"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Fazioni figlie" name="page_child_factions">
                                <field name="child_ids" nolabel="1" colspan="2"/>
                            </page>
                            <page string="Scontri" name="page_encounters">
                                <field name="encounter_ids" nolabel="1" colspan="2">
                                    <tree>
                                        <field name="sml"/>
                                        <field name="name"/>
                                        <field name="exp_adj"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
