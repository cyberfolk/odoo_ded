<odoo>
    <record id="creature_creature_view_search" model="ir.ui.view">
        <field name="name">creature.creature.search</field>
        <field name="model">creature.creature</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="cr"/>
                <field name="type_id"/>
                <field name="tag_ids"/>
                <field name="biome_low_prob_ids"/>
                <field name="biome_high_prob_ids"/>
                <field name="biome_ids"/>
                <filter name="filter_tag_cool" string="Interessante" domain="[('is_cool', '=', True)]"/>
                <filter name="filter_tag_skip" string="Sconosciuta" domain="[('is_skip', '=', True)]"/>
                <separator/>
                <filter name="filter_tag_not_violent" string="Non Violento" domain="[('is_not_violent', '=', True)]"/>
                <filter name="filter_tag_innocuous" string="Innocuo" domain="[('is_innocuous', '=', True)]"/>
                <filter name="filter_tag_endemic" string="Endemico" domain="[('is_endemic', '=', True)]"/>
                <separator/>
                <filter name="filter_tag_boss" string="Boss" domain="[('is_boss', '=', True)]"/>
                <filter name="filter_tag_social" string="Sociale" domain="[('is_social', '=', True)]"/>
                <separator/>
                <filter name="filter_no_tag_ids" string="No Tag" domain="[('tag_ids', '=', False)]"/>
                <filter name="filter_no_biome_ids" string="No Biomi" domain="[('biome_ids', '=', False)]"/>
                <filter name="groupby_biome_ids" string="Biomi" context="{'group_by': 'biome_ids'}"/>
                <filter name="groupby_type_id" string="Tipi" context="{'group_by': 'type_id'}"/>
                <filter name="groupby_tag_ids" string="Tag" context="{'group_by': 'tag_ids'}"/>
            </search>
        </field>
    </record>

    <record id="creature_creature_view_tree" model="ir.ui.view">
        <field name="name">creature.creature.tree</field>
        <field name="model">creature.creature</field>
        <field name="arch" type="xml">
            <tree decoration-bf="is_cool" decoration-muted="is_skip">
                <field name="is_skip" column_invisible="1"/>
                <field name="is_cool" column_invisible="1"/>
                <field name="name"/>
                <field name="link_5et" widget="url" text="Link 5etools"/>
                <field name="cr"/>
                <field name="type_id"/>
                <field name="tag_ids" widget="many2many_tags"/>
                <field name="biome_low_prob_ids" widget="many2many_tags"/>
                <field name="biome_high_prob_ids" widget="many2many_tags"/>
                <field name="faction_ids" widget="many2many_tags"/>
            </tree>
        </field>
    </record>

    <record id="creature_creature_view_form" model="ir.ui.view">
        <field name="name">creature.creature.form</field>
        <field name="model">creature.creature</field>
        <field name="arch" type="xml">
            <form>
                <header/>
                <sheet>
                    <group col="6">
                        <group colspan="4">
                            <div class="oe_title mb-3" colspan="2">
                                <group class="d-flex">
                                    <field name="is_base" invisible="1"/>
                                    <field name="is_legendary" string="ML"/>
                                    <field name="is_npc"/>
                                </group>
                                <!--                                <label for="name" class="fw-bold oe_inline mb-0"/>-->
                                <h1 name="h1_name">
                                    <field class="text-nowrap" name="name" nolabel="1" placeholder="Nome..."/>
                                </h1>
                                <field name="link_5et" invisible="not is_base" widget="url" readonly="1" text="Link 5etools"/>
                                <h3 name="h3_titles" invisible="not is_npc">
                                    <field class="text-nowrap text-muted" name="titles" nolabel="1" placeholder="Titoli..."/>
                                </h3>
                            </div>
                            <group string="Info Base" name="group_fields_base">
                                <div name="div_cr_exp" class="w-100 d-flex" colspan="2">
                                    <div style="width: 15%" class="o_form_label fw-bold pe-3">GS</div>
                                    <field style="width: 8%" name="cr"/>
                                    <div class="o_form_label fw-bold ps-3">&#8594;</div>
                                    <div class="o_form_label fw-bold px-3">Exp</div>
                                    <field style="width: 36%" name="exp"/>
                                </div>
                                <field name="tag_ids" widget="many2many_tags"/>
                                <field name="biome_high_prob_ids" widget="many2many_tags" invisible="not is_base"/>
                                <field name="biome_low_prob_ids" widget="many2many_tags" invisible="not is_base"/>
                                <field name="type_id"/>
                            </group>
                            <group string="Entità Narrative" invisible="not is_base" name="group_fields_en_base">
                                <field widget="many2many_tags" string="Mostri Leggendari" name="monster_ids"/>
                                <field widget="many2many_tags" string="Punti d'Interesse" name="poi_ids"/>
                                <field widget="many2many_tags" string="Missioni" name="quest_ids"/>
                                <field widget="many2many_tags" string="Creature" name="creature_ids"/>
                                <field widget="many2many_tags" string="Fazioni" name="faction_ids"/>
                                <field widget="many2many_tags" string="NPCs" name="npc_ids"/>
                                <field widget="many2many_tags" string="Insediamenti" name="settlement_ids"/>
                                <field widget="many2many_tags" string="Lore Items" name="lore_item_ids"/>
                            </group>
                            <group string="Entità Narrative" invisible="not is_npc" name="group_fields_en_npc">
                                <field widget="many2many_tags" string="Mostri Leggendari" name="monster_npc_ids"/>
                                <field widget="many2many_tags" string="Punti d'Interesse" name="poi_npc_ids"/>
                                <field widget="many2many_tags" string="Missioni" name="quest_npc_ids"/>
                                <field widget="many2many_tags" string="Creature" name="creature_npc_ids"/>
                                <field widget="many2many_tags" string="Fazioni" name="faction_npc_ids"/>
                                <field widget="many2many_tags" string="NPCs" name="npc_npc_ids"/>
                                <field widget="many2many_tags" string="Insediamenti" name="settlement_npc_ids"/>
                                <field widget="many2many_tags" string="Lore Items" name="lore_item_npc_ids"/>
                            </group>
                            <group string="Entità Narrative" invisible="not is_legendary" name="group_fields_en_legendary">
                                <field widget="many2many_tags" string="Mostri Leggendari" name="monster_monster_ids"/>
                                <field widget="many2many_tags" string="Punti d'Interesse" name="poi_monster_ids"/>
                                <field widget="many2many_tags" string="Missioni" name="quest_monster_ids"/>
                                <field widget="many2many_tags" string="Creature" name="creature_monster_ids"/>
                                <field widget="many2many_tags" string="Fazioni" name="faction_monster_ids"/>
                                <field widget="many2many_tags" string="NPCs" name="npc_monster_ids"/>
                                <field widget="many2many_tags" string="Insediamenti" name="settlement_monster_ids"/>
                                <field widget="many2many_tags" string="Lore Items" name="lore_item_monster_ids"/>
                            </group>
                        </group>
                        <group colspan="2">
                            <field name="image" widget="image" nolabel="1" colspan="2"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="Descrizione">
                            <group invisible="not is_npc">
                                <group>
                                    <field name="appearance" placeholder="..."/>
                                    <field name="social_role" placeholder="..."/>
                                    <field name="pc_relation" placeholder="..."/>
                                </group>
                                <group>
                                    <field name="motivation" placeholder="..."/>
                                    <field name="needs" placeholder="..."/>
                                    <field name="offers" placeholder="..."/>
                                </group>
                            </group>
                            <group>
                                <field name="description" nolabel="1" colspan="2" placeholder="Descrizione..."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>