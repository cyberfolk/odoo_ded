<odoo>
    <record id="creature_legendary_view_tree" model="ir.ui.view">
        <field name="name">creature_legendary_view_tree</field>
        <field name="model">creature.creature</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <record id="creature_legendary_view_form" model="ir.ui.view">
        <field name="name">creature_legendary_view_form</field>
        <field name="model">creature.creature</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group col="6">
                        <group colspan="4">
                            <div class="oe_title mb-3" colspan="2">
                                <label for="name" class="fw-bold oe_inline mb-0"/>
                                <h1>
                                    <field class="text-nowrap" name="name" nolabel="1"/>
                                </h1>
                                <group>
                                    <group>
                                        <field name="is_legendary"/>
                                        <field name="is_npc"/>
                                    </group>
                                </group>
                            </div>
                            <group>
                                <field name="type_id"/>
                                <field name="tag_ids" widget="many2many_tags"/>
                                <div name="div_cr_exp" class="w-100 d-flex" colspan="2">
                                    <div style="width: 15%" class="o_form_label fw-bold pe-3">GS</div>
                                    <field style="width: 8%" name="cr"/>
                                    <div class="o_form_label fw-bold ps-3">&#8594;</div>
                                    <div class="o_form_label fw-bold px-3">Exp</div>
                                    <field style="width: 36%" name="exp"/>
                                </div>
                            </group>
                            <group>
                                <field name="ml_quest_ids" widget="many2many_tags"/>
                                <field name="ml_poi_ids" widget="many2many_tags"/>
                                <field name="ml_npc_ids" widget="many2many_tags"/>
                                <field name="ml_faction_ids" widget="many2many_tags"/>
                            </group>
                        </group>
                        <group colspan="2">
                            <field name="image" widget="image" nolabel="1" colspan="2"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Descrizione" name="page_description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>