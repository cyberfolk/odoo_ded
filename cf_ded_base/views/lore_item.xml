<odoo>
    <record id="lore_item_view_tree" model="ir.ui.view">
        <field name="name">lore.item.tree</field>
        <field name="model">lore.item</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <record id="lore_item_view_form" model="ir.ui.view">
        <field name="name">lore.item.form</field>
        <field name="model">lore.item</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <widget name="web_ribbon" title="Lore Alta" bg_color="text-bg-danger" invisible="type == 'low'"/>
                    <widget name="web_ribbon" title="Lore Bassa" bg_color="text-bg-success" invisible="type == 'high'"/>
                    <group col="6">
                        <group colspan="4">
                            <div class="oe_title mb-3" colspan="2">
                                <label for="name" class="fw-bold oe_inline mb-0"/>
                                <h1>
                                    <field class="text-nowrap" name="name" nolabel="1"/>
                                </h1>
                                <h3 class="text-muted fst-italic">
                                    <field class="text-nowrap" name="complete_name" nolabel="1"/>
                                </h3>
                            </div>
                            <group string="Info Base" name="group_fields_base">
                                <field name="parent_id" string="Padre"/>
                                <field name="type"/>
                                <field name="code" class="text-nowrap text-muted fst-italic" readonly="1" groups="base.group_no_one"/>
                            </group>
                            <group string="Entità Narrative" name="group_fields_en_base">
                                <field widget="many2many_tags" name="monster_ids"/>
                                <field widget="many2many_tags" name="poi_ids"/>
                                <field widget="many2many_tags" name="settlement_ids"/>
                                <field widget="many2many_tags" name="artifact_ids"/>
                                <field widget="many2many_tags" name="quest_ids"/>
                                <field widget="many2many_tags" name="creature_ids"/>
                                <field widget="many2many_tags" name="faction_ids"/>
                                <field widget="many2many_tags" name="npc_ids"/>
                            </group>
                        </group>
                        <group colspan="2">
                            <field name="image" widget="image" nolabel="1" colspan="2"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="Descrizione">
                            <field name="description"/>
                        </page>
                        <page name="Lore Item Figli">
                            <field name="child_ids" nolabel="1" colspan="2">
                                <tree editable="top">
                                    <field name="name"/>
                                    <field name="description"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
