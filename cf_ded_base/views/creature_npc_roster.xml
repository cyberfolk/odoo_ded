<odoo>
    <record id="creature_rooster_view_tree" model="ir.ui.view">
        <field name="name">creature.roster.tree</field>
        <field name="model">creature.roster</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="creature_ids" widget="many2many_tags"/>
            </tree>
        </field>
    </record>

    <record id="creature_rooster_view_form" model="ir.ui.view">
        <field name="name">creature.roster.form</field>
        <field name="model">creature.roster</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title" colspan="2">
                        <label for="name" class="oe_inline"/>
                        <h1>
                            <field class="text-nowrap" name="name" nolabel="1"/>
                        </h1>
                    </div>
                    <group class="mt-3">
                        <group>
                            <field name="creature_ids"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
