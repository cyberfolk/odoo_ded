<odoo>
    <record id="point_of_interest_view_tree" model="ir.ui.view">
        <field name="name">point_of_interest_view_tree</field>
        <field name="model">point.of.interest</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <record id="point_of_interest_view_form" model="ir.ui.view">
        <field name="name">point_of_interest_view_form</field>
        <field name="model">point.of.interest</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group col="6">
                        <group colspan="4">
                            <div class="oe_title mb-3" colspan="2">
                                <label for="name" class="fw-bold oe_inline mb-0"/>
                                <h1>
                                    <field class="text-nowrap" name="name" nolabel="1"/>
                                </h1>
                            </div>
                            <group>
                                <field name="quest_ids" widget="many2many_tags"/>
                                <field name="creature_ids" widget="many2many_tags" string="Mostri" domain="[('is_legendary', '=', True)]"/>
                                <field name="creature_ids" widget="many2many_tags" string="NPCs" domain="[('is_npc', '=', True)]"/>
                                <field name="faction_ids" widget="many2many_tags"/>
                            </group>
                        </group>
                        <group colspan="2">
                            <field name="image" widget="image" nolabel="1" colspan="2"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Descrizione" name="page_description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>