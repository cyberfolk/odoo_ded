<odoo>
    <record id="campaign_pg_view_tree" model="ir.ui.view">
        <field name="name">campaign.pg.tree.base</field>
        <field name="model">campaign.pg</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="player_id"/>
                <field name="level"/>
                <field name="exp"/>
                <field name="class_s"/>
                <field name="race_s"/>
                <field name="campaign_id"/>
            </tree>
        </field>
    </record>

    <record id="campaign_pg_view_form" model="ir.ui.view">
        <field name="name">campaign.pg.form.base</field>
        <field name="model">campaign.pg</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title" colspan="2">
                        <label for="name" class="oe_inline"/>
                        <h1>
                            <field class="text-nowrap" name="name" nolabel="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="campaign_id"/>
                            <field name="player_id"/>
                            <field name="exp"/>
                            <field name="level"/>
                            <field name="race_s"/>
                            <field name="class_s"/>
                        </group>
                        <group>
                            <field colspan="2" name="image" widget="image" nolabel="1" style="width: 50%"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Descrizione" name="page_description">
                            <field name="description"/>
                        </page>
                        <page string="Storico Exp" name="page_description">
                            <field name="session_pg_ids" nolabel="1" colspan="2">
                                <tree editable="bottom">
                                    <field name="date"/>
                                    <field string="Exp I" name="exp_start" class="text-end"/>
                                    <field string="Liv I" name="liv_start" class="text-center text-muted"/>
                                    <field string="Exp Bar" name="exp_bar" class="text-center text-muted"/>
                                    <field string="Exp Liv Up" name="exp_next_level" class="text-center text-muted"/>
                                    <field string="R%" name="role_percentage" widget="percentage"/>
                                    <field string="Ruolo" name="role"/>
                                    <field string="A%" name="help_percentage" widget="percentage"/>
                                    <field string="Aiuto" name="help"/>
                                    <field string="RP%" name="rp_percentage" widget="percentage"/>
                                    <field string="RP" name="rp" help="Role Play"/>
                                    <field string="Exp R" name="role_exp" class="cf-bg-highlight text-center"/>
                                    <field string="Exp A" name="help_exp" class="cf-bg-highlight text-center"/>
                                    <field string="Exp RP" name="rp_exp" class="cf-bg-highlight text-center"/>
                                    <field string="Exp Presa" name="exp_gained_total" class="text-center"/>
                                    <field string="Exp F" name="exp_end"/>
                                    <field string="Exp FF" name="exp_end_adj"/>
                                    <field string="Liv F" name="liv_end" style="text-align: center;"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>