<odoo>
    <record id="action_menu_campaign_campaign" model="ir.actions.act_window">
        <field name="name">Campagne</field>
        <field name="res_model">campaign.campaign</field>
        <field name="view_mode">tree,form</field>
    </record>
    <record id="action_menu_campaign_session" model="ir.actions.act_window">
        <field name="name">Sessioni</field>
        <field name="res_model">campaign.session</field>
        <field name="view_mode">tree,form</field>
    </record>
    <record id="action_menu_campaign_pg" model="ir.actions.act_window">
        <field name="name">PG</field>
        <field name="res_model">campaign.pg</field>
        <field name="view_mode">tree,form</field>
    </record>
    <record id="action_menu_res_partner_player" model="ir.actions.act_window">
        <field name="name">Player/Master</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('rpg_type', '!=', None)]</field>
    </record>
    <record id="action_menu_campaign_mission" model="ir.actions.act_window">
        <field name="name">Missioni</field>
        <field name="res_model">campaign.mission</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem sequence="3" id="menu_hex" name="Campagne" parent="cf_hex_base.menu_root">
        <menuitem sequence="1" id="menu_campaign_campaign" name="Campagne" action="action_menu_campaign_campaign"/>
        <menuitem sequence="2" id="menu_campaign_session" name="Sessioni" action="action_menu_campaign_session"/>
        <menuitem sequence="3" id="menu_campaign_res_partner_player" name="Player/Master"
                  action="action_menu_res_partner_player"/>
        <menuitem sequence="4" id="menu_campaign_pg" name="PG" action="action_menu_campaign_pg"/>
        <menuitem sequence="5" id="menu_campaign_mission" name="Missioni" action="action_menu_campaign_mission"/>
    </menuitem>
    <menuitem sequence="2" id="menu_contacts_res_partner_player" name="Player/Master" parent="contacts.menu_contacts"
              action="action_menu_res_partner_player"/>

</odoo>
