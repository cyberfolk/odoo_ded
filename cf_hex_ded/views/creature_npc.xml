<odoo>
    <record id="creature_npc_view_tree_inherited" model="ir.ui.view">
        <field name="name">creature.npc.tree.lore</field>
        <field name="model">creature.npc</field>
        <field name="inherit_id" ref="cf_ded_base.creature_npc_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='faction_ids']" position="after">
                <field name="hex_ids" widget="many2many_tags"/>
            </xpath>
        </field>
    </record>

    <record id="creature_npc_view_form_inherited_script" model="ir.ui.view">
        <field name="name">creature.npc.form.scripted</field>
        <field name="model">creature.npc</field>
        <field name="inherit_id" ref="cf_ded_base.creature_npc_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='poi_ids']" position="before">
                <field name="hex_ids" widget="many2many_tags"/>
            </xpath>
        </field>
    </record>
</odoo>
