<odoo>
    <record id="artifact_artifact_view_form" model="ir.ui.view">
        <field name="name">artifact_artifact_view_form</field>
        <field name="model">artifact.artifact</field>
        <field name="inherit_id" ref="cf_ded_base.artifact_artifact_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='npc_ids']" position="after">
                <field name="hex_ids" widget="many2many_tags"/>
            </xpath>
        </field>
    </record>
</odoo>
