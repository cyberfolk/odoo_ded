<odoo>
    <record id="hex_map_view_tree" model="ir.ui.view">
        <field name="name">hex_map_view_tree</field>
        <field name="model">hex.map</field>
        <field name="inherit_id" ref="cf_hex_base.hex_map_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='type']" position="attributes">
                <attribute name="decoration-warning">type == 'v3_no_q'</attribute>
            </xpath>
        </field>
    </record>

    <record id="hex_map_view_form" model="ir.ui.view">
        <field name="name">hex_map_view_form</field>
        <field name="model">hex.map</field>
        <field name="inherit_id" ref="cf_hex_base.hex_map_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='type']" position="attributes">
                <attribute name="decoration-warning">type == 'v3_no_q'</attribute>
            </xpath>
            <xpath expr="//tree/field[@name='code']" position="after">
                <field name="row" column_invisible="parent.type != 'v3_no_q'"/>
                <field name="col" column_invisible="parent.type != 'v3_no_q'"/>
            </xpath>
            <xpath expr="//page[@name='page_quad_ids']" position="before">
                <page string="Esagoni" name="page_hex_ids">
                    <field name="hex_ids">
                        <tree delete="0" create="0" edit="0">
                            <field name="name"/>
                            <field name="code"/>
                            <field name="row"/>
                            <field name="col"/>
                        </tree>
                    </field>
                </page>
            </xpath>
            <xpath expr="//page[@name='page_quad_ids']" position="after">
                <page string="Righe Colonne" name="page_row_col2" invisible="type != 'v3_no_q'">
                    <group name="group_row_col2">
                        <field string="Indice riga minore" name="row_min"/>
                        <field string="Indice riga maggiore" name="row_max"/>
                        <field string="Numero righe" name="row_num"/>
                        <field string="Indice colonna minore" name="col_min"/>
                        <field string="Indice colonna maggiore" name="col_max"/>
                        <field string="Numero colonne" name="col_num"/>
                    </group>
                </page>
            </xpath>
            <xpath expr="//page[@name='page_quad_ids']" position="attributes">
                <attribute name="invisible">type == 'v3_no_q'</attribute>
            </xpath>
        </field>
    </record>
</odoo>
