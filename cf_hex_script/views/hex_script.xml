<odoo>
    <record id="hex_script_view_tree" model="ir.ui.view">
        <field name="name">hex.script.tree</field>
        <field name="model">hex.script</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="biome_id"/>
                <field name="hex_id"/>
                <field name="sml"/>
                <field name="npc_ids" widget="many2many_tags"/>
                <field name="faction_ids" widget="many2many_tags"/>
                <field name="structure_id"/>
                <field name="creature_id"/>
            </tree>
        </field>
    </record>

    <record id="hex_script_view_form" model="ir.ui.view">
        <field name="name">hex.script.form</field>
        <field name="model">hex.script</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title" colspan="2">
                        <label for="name" class="oe_inline"/>
                        <h1>
                            <field class="text-nowrap" name="name" nolabel="1"/>
                        </h1>
                    </div>
                    <group class="mt-3">
                        <group colspan="2">
                            <field name="description"/>
                            <field name="biome_id" required="1"/>
                            <field name="hex_id" domain="[('hex_script_id', '=', False)]"/>
                            <field name="sml" required="1"/>
                            <field name="wild_encounter_ids"/>
                            <field name="random_encounter_ids"/>
                            <field name="image_primary" widget="image"/>
                            <field name="npc_ids"/>
                            <field name="structure_id"/>
                            <field name="creature_id"/>
                            <field name="image_secondary_ids" widget="many2many_binary"/>
                            <field name="image_secondary_ids" widget="MultipleImage"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>