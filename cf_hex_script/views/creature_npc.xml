<odoo>
    <record id="creature_npc_view_tree" model="ir.ui.view">
        <field name="name">creature.npc.tree</field>
        <field name="model">creature.npc</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="tag_ids" widget="many2many_tags"/>
                <field name="type_id"/>
                <field name="faction_ids" widget="many2many_tags"/>
                <field name="hex_script_ids" widget="many2many_tags"/>
            </tree>
        </field>
    </record>

    <record id="creature_npc_view_form" model="ir.ui.view">
        <field name="name">creature.npc.form</field>
        <field name="model">creature.npc</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title" colspan="2">
                        <label for="name" class="oe_inline"/>
                        <h1>
                            <field class="text-nowrap" name="name" nolabel="1"/>
                        </h1>
                    </div>
                    <group class="mt-3">
                        <group>
                            <field name="cr"/>
                            <field name="exp"/>
                            <field name="tag_ids" widget="many2many_tags"/>
                            <field name="type_id"/>
                            <field name="faction_ids" widget="many2many_tags"/>
                            <field name="description"/>
                            <field name="image_primary"/>
                            <field name="hex_script_ids" widget="many2many_tags"/>
                            <field name="creature_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
