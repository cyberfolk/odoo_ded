<odoo>
    <record id="creature_npc_view_tree_inherited_script" model="ir.ui.view">
        <field name="name">creature.npc.tree.scripted</field>
        <field name="model">creature.npc</field>
        <field name="inherit_id" ref="cf_hex_biome.creature_npc_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='faction_ids']" position="after">
                <field name="hex_script_ids" widget="many2many_tags"/>
            </xpath>
        </field>
    </record>

    <record id="creature_npc_view_form_inherited_script" model="ir.ui.view">
        <field name="name">creature.npc.form.scripted</field>
        <field name="model">creature.npc</field>
        <field name="inherit_id" ref="cf_hex_biome.creature_npc_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='creature_id']" position="after">
                <field name="hex_script_ids" widget="many2many_tags"/>
            </xpath>
        </field>
    </record>
</odoo>
