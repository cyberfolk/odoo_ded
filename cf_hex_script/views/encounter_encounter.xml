<odoo>
    <record id="encounter_encounter_view_tree" model="ir.ui.view">
        <field name="name">encounter.encounter.tree</field>
        <field name="model">encounter.encounter</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="description"/>
                <field name="hex_script_id"/>
            </tree>
        </field>
    </record>

    <record id="encounter_encounter_view_form" model="ir.ui.view">
        <field name="name">encounter.encounter.form</field>
        <field name="model">encounter.encounter</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title" colspan="2">
                        <label for="name" class="oe_inline"/>
                        <h1>
                            <field class="text-nowrap" name="name" nolabel="1"/>
                        </h1>
                    </div>
                    <group class="mt-3">
                        <group>
                            <field name="description"/>
                            <field name="hex_script_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>