<div t-name="HideShow" class="hide-show mt-2">
    <div class="hide-show__title">
        <span>Mostra / Nascondi</span>
    </div>

    <div class="hide-show__color-list mx-1 row">
        <div class="form-check">
            <input class="form-check-input rounded" type="checkbox" t-model="store.showHexCode" id="inputShowHexCode"/>
            <label class="form-check-label" for="inputShowHexCode">
                <span class="fw-bold">Mostra Codice Esagoni</span>
            </label>
        </div>
        <div class="form-check">
            <input class="form-check-input rounded" type="checkbox" t-model="store.showHexSml" id="inputShowHexSml"/>
            <label class="form-check-label" for="inputShowHexSml">
                <span class="fw-bold">Mostra SML Esagoni</span>
            </label>
        </div>
    </div>
</div>
