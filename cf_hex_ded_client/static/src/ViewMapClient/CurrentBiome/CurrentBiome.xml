<div t-name="CurrentBiome" class="current-biome mt-2">
    <div class="current-biome__title" t-att-class="store.currentBiome ? 'd-none' : ''">
        <span>Colloca Bioma</span>
    </div>

    <div class="current-biome__hide-title" t-att-class="store.currentBiome ? 'd-block' : ''">
        <span>Scegli un Bioma e collocalo sugli Esagoni:</span>
    </div>
    <div class="current-biome__color-list mx-1 row">
        <t t-foreach="store.biomeList" t-as="biome" t-key="biome.name">
            <button class="current-biome__btn btn p-2 me-1"
                    t-att-style="'background-color: ' + biome.color + '; color: ' + biome.color_name_contrast"
                    t-on-click="() => this.setCurrentBiome(biome)"
                    t-att-class="store.currentBiome == biome.color ? 'current-biome__btn--active' : ''"
                    t-esc="biome.name">
            </button>
        </t>
    </div>
</div>
